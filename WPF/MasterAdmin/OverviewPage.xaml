<UserControl x:Class="MasterAdmin.OverviewPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:MasterAdmin"
             mc:Ignorable="d"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"   Value="{DynamicResource BgCard}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding"      Value="14"/>
            <Setter Property="Margin"       Value="4"/>
        </Style>
        <Style x:Key="SecTitle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource FgSecondary}"/>
            <Setter Property="Margin"     Value="0,0,0,8"/>
        </Style>
        <Style x:Key="BigNum" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="26"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource FgPrimary}"/>
        </Style>
        <Style x:Key="SubLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource FgMuted}"/>
            <Setter Property="Margin"     Value="0,2,0,0"/>
        </Style>
        <Style x:Key="DG" TargetType="DataGrid">
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="Foreground"               Value="{DynamicResource FgData}"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="RowBackground"            Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource BgAltRow}"/>
            <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderLine}"/>
            <Setter Property="ColumnHeaderHeight"       Value="30"/>
            <Setter Property="RowHeight"                Value="26"/>
            <Setter Property="FontSize"                 Value="11"/>
            <Setter Property="SelectionMode"            Value="Single"/>
            <Setter Property="AutoGenerateColumns"      Value="False"/>
            <Setter Property="IsReadOnly"               Value="True"/>
            <Setter Property="CanUserResizeRows"        Value="False"/>
            <Setter Property="CanUserAddRows"           Value="False"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        </Style>
        <Style x:Key="DGH" TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="{DynamicResource BgColHead}"/>
            <Setter Property="Foreground"      Value="{DynamicResource FgMuted}"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderLine}"/>
        </Style>
        <Style x:Key="SmallBtn" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource SmBtnBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource SmBtnFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 요약 카드 -->
            <RowDefinition Height="*"/>
            <!-- 메인 콘텐츠 -->
        </Grid.RowDefinitions>

        <!-- ══ 요약 카드 ══ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="총 처리" Style="{StaticResource SecTitle}"/>
                    <TextBlock Text="{Binding StatsTotalCount}" Style="{StaticResource BigNum}" Foreground="#FB923C"/>
                    <TextBlock Text="오늘 처리 건수" Style="{StaticResource SubLabel}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="오류 건수" Style="{StaticResource SecTitle}"/>
                    <TextBlock Text="{Binding StatsErrorCount}" Style="{StaticResource BigNum}" Foreground="#F87171"/>
                    <TextBlock Text="오늘 발생" Style="{StaticResource SubLabel}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="공장 CCTV" Style="{StaticResource SecTitle}"/>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="11" Height="11" Fill="#4ADE80" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock Text="실시간" Style="{StaticResource BigNum}" Foreground="#38BDF8"/>
                    </StackPanel>
                    <TextBlock Text="공장 전체 모니터링" Style="{StaticResource SubLabel}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="시스템 가동률" Style="{StaticResource SecTitle}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding DeviceStatus.SuccessRate}" Style="{StaticResource BigNum}" Foreground="#4ADE80"/>
                        <TextBlock Text=" %" FontSize="16" Foreground="#4ADE80" VerticalAlignment="Bottom" Margin="1,0,0,4"/>
                    </StackPanel>
                    <TextBlock Text="금일 기준" Style="{StaticResource SubLabel}"/>
                </StackPanel>
            </Border>
        </Grid>



        <!-- ══ 메인 콘텐츠 ══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <!-- 왼쪽: 블랙박스+통계 -->
                <ColumnDefinition Width="0.75*"/>
                <!-- 오른쪽: 로그인 -->
            </Grid.ColumnDefinitions>

            <!-- ═ 통계 (Col0) ═ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <!-- 통계 그래프 -->
                </Grid.RowDefinitions>

                <!-- ═ 통계 그래프 ═ -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 권역별 분류 현황 막대 그래프 -->
                    <Border Grid.Row="0" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <TextBlock Text="▌ " Foreground="#38BDF8" FontSize="14"/>
                                    <TextBlock Text="권역별 분류 현황" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource FgPrimary}"/>
                                </StackPanel>
                                <!-- 범례 — 제목 옆 오른쪽 -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Rectangle Width="10" Height="10" Fill="#38BDF8" RadiusX="2" RadiusY="2" Margin="0,0,4,0"/>
                                    <TextBlock Text="정상" FontSize="9" Foreground="{DynamicResource FgMuted}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <Rectangle Width="10" Height="10" Fill="#F87171" RadiusX="2" RadiusY="2" Margin="0,0,4,0"/>
                                    <TextBlock Text="불량" FontSize="9" Foreground="{DynamicResource FgMuted}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <!-- 막대 그래프 -->
                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Y축 + 막대들 -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <!-- Y축 라벨 -->
                                        <ColumnDefinition Width="*"/>
                                        <!-- 그래프 영역 -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Y축 라벨 (RegionAxisLabels: 위→아래 5개, 통계 최대값 기준) -->
                                    <ItemsControl Grid.Column="0" ItemsSource="{Binding RegionAxisLabels}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Rows="5"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontSize="8" Foreground="{DynamicResource FgMuted}"
                                                           HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,3,0"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- 그래프 -->
                                    <Grid Grid.Column="1">
                                        <!-- 수평 격자선 -->
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Top" Fill="{DynamicResource BorderLine}" Opacity="0.5"/>
                                            <Rectangle Grid.Row="1" Height="1" VerticalAlignment="Top" Fill="{DynamicResource BorderLine}" Opacity="0.5"/>
                                            <Rectangle Grid.Row="2" Height="1" VerticalAlignment="Top" Fill="{DynamicResource BorderLine}" Opacity="0.5"/>
                                            <Rectangle Grid.Row="3" Height="1" VerticalAlignment="Top" Fill="{DynamicResource BorderLine}" Opacity="0.5"/>
                                            <Rectangle Grid.Row="4" Height="1" VerticalAlignment="Top" Fill="{DynamicResource BorderLine}" Opacity="0.5"/>
                                        </Grid>

                                        <!-- 막대 그래프 (정상/불량 쌓기) — RegionBars 바인딩 -->
                                        <!--   값 있는 권역만 받아 그 개수만큼 막대를 그린다(현재 서울/경기도 2개). -->
                                        <ItemsControl ItemsSource="{Binding RegionBars}" Margin="4,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Rows="1"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel VerticalAlignment="Bottom" Margin="2,0">
                                                        <Border Height="{Binding NormalHeight}"
                                                                Background="{Binding DataContext.RegionNormalBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CornerRadius="3,3,0,0">
                                                            <TextBlock Text="{Binding Normal}" FontSize="8" Foreground="White"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,2"/>
                                                        </Border>
                                                        <Border Height="{Binding DefectHeight}"
                                                                Background="{Binding DataContext.RegionDefectBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CornerRadius="0">
                                                            <TextBlock Text="{Binding Defect}" FontSize="8" Foreground="White"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- 빈 상태: 통계 데이터(권역)가 아직 없을 때 -->
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                                    Visibility="{Binding RegionBars.Count, Converter={StaticResource CountToVis}}">
                                            <TextBlock Text="데이터 없음" FontSize="12" Foreground="{DynamicResource FgMuted}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="(통계 API 연결 대기)" FontSize="9" Foreground="#475569" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>

                                <!-- X축 라벨 (RegionBars 바인딩 — 막대와 같은 권역 순서) -->
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding RegionBars}" Margin="32,3,4,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" FontSize="9" Foreground="{DynamicResource FgMuted}" HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- 인식 방식 / 오류 유형 도넛 차트 -->
                    <Border Grid.Row="1" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="▌ " Foreground="#C084FC" FontSize="14"/>
                                <TextBlock Text="분류 통계" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource FgPrimary}"/>
                            </StackPanel>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 인식 방식 비율 — RecognitionSlices 바인딩 (도넛 조각은 C#에서 계산) -->
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="인식 방식" FontSize="10" Foreground="{DynamicResource FgMuted}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <!-- 원형 시각화 (WPF Path) -->
                                    <Grid Width="80" Height="80">
                                        <ItemsControl ItemsSource="{Binding RecognitionSlices}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><Canvas/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Path Fill="{Binding Brush}" Data="{Binding Geometry}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Ellipse Width="50" Height="50" Fill="{DynamicResource BgCard}"/>
                                        <!-- 중앙 라벨/값 — 세로로 쌓아 겹침 방지 -->
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                                    Visibility="{Binding RecognitionSlices.Count, Converter={StaticResource CountToVis}, ConverterParameter=invert}">
                                            <TextBlock Text="{Binding RecognitionCenterLabel}" FontSize="9" Foreground="#38BDF8" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding RecognitionCenterValue}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource FgPrimary}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <!-- 빈 상태 -->
                                        <TextBlock Text="데이터 없음" FontSize="9" Foreground="{DynamicResource FgMuted}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Visibility="{Binding RecognitionSlices.Count, Converter={StaticResource CountToVis}}"/>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding RecognitionSlices}" Margin="0,8,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2">
                                                    <Rectangle Width="8" Height="8" Fill="{Binding Brush}" RadiusX="2" RadiusY="2" Margin="0,0,4,0"/>
                                                    <TextBlock Text="{Binding Display}" FontSize="9" Foreground="{DynamicResource FgMuted}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- 오류 유형 비율 — ErrorTypeSlices 바인딩 (조각 수는 백엔드가 결정) -->
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="오류 유형" FontSize="10" Foreground="{DynamicResource FgMuted}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <Grid Width="80" Height="80">
                                        <ItemsControl ItemsSource="{Binding ErrorTypeSlices}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><Canvas/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Path Fill="{Binding Brush}" Data="{Binding Geometry}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Ellipse Width="50" Height="50" Fill="{DynamicResource BgCard}"/>
                                        <!-- 중앙 라벨/값 — 세로로 쌓아 겹침 방지 -->
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                                    Visibility="{Binding ErrorTypeSlices.Count, Converter={StaticResource CountToVis}, ConverterParameter=invert}">
                                            <TextBlock Text="오류" FontSize="9" Foreground="#F87171" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding ErrorCenterValue}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource FgPrimary}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <!-- 빈 상태 -->
                                        <TextBlock Text="데이터 없음" FontSize="9" Foreground="{DynamicResource FgMuted}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Visibility="{Binding ErrorTypeSlices.Count, Converter={StaticResource CountToVis}}"/>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding ErrorTypeSlices}" Margin="0,8,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2">
                                                    <Rectangle Width="8" Height="8" Fill="{Binding Brush}" RadiusX="2" RadiusY="2" Margin="0,0,4,0"/>
                                                    <TextBlock Text="{Binding Display}" FontSize="9" Foreground="{DynamicResource FgMuted}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>


            <!-- ═ 공장 전체 CCTV ═ -->
            <!--   현우 노트북(192.168.0.39)의 cctv_stream.py가 송출하는 MJPEG 스트림을
                   QR캠과 동일한 네트워크 URL 방식으로 표시. 컨트롤 이름(CamCctvImg/
                   CamCctvPlaceholder)은 OverviewPage.xaml.cs의 변수와 일치시켜야 함. -->
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="▌ " Foreground="#38BDF8" FontSize="14"/>
                        <TextBlock Text="공장 전체 CCTV" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource FgPrimary}"/>
                        <TextBlock Text="  LIVE" FontSize="10" Foreground="#4ADE80" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Grid.Row="1" Background="#050E1A" CornerRadius="6" ClipToBounds="True">
                        <Grid>
                            <Image x:Name="CamCctvImg" Stretch="Uniform"/>
                            <StackPanel x:Name="CamCctvPlaceholder" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="📷" FontSize="26" HorizontalAlignment="Center"/>
                                <TextBlock Text="공장 전체 CCTV" FontSize="11" Foreground="#38BDF8"
                                           HorizontalAlignment="Center" Margin="0,5,0,0" FontFamily="Consolas"/>
                                <TextBlock Text="CCTV 연결 대기" FontSize="9" Foreground="#475569"
                                           HorizontalAlignment="Center" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
