<UserControl x:Class="MasterAdmin.OverviewPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:MasterAdmin"
             mc:Ignorable="d"
             Background="Transparent">
  <UserControl.Resources>

    <Style x:Key="Card" TargetType="Border">
      <Setter Property="Background"   Value="#1E2A3A"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding"      Value="14"/>
      <Setter Property="Margin"       Value="4"/>
    </Style>

    <Style x:Key="SecTitle" TargetType="TextBlock">
      <Setter Property="FontSize"   Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#94A3B8"/>
      <Setter Property="Margin"     Value="0,0,0,8"/>
    </Style>

    <Style x:Key="BigNum" TargetType="TextBlock">
      <Setter Property="FontSize"   Value="26"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Foreground" Value="#F1F5F9"/>
    </Style>

    <Style x:Key="SubLabel" TargetType="TextBlock">
      <Setter Property="FontSize"   Value="11"/>
      <Setter Property="Foreground" Value="#64748B"/>
      <Setter Property="Margin"     Value="0,2,0,0"/>
    </Style>

    <Style x:Key="DG" TargetType="DataGrid">
      <Setter Property="Background"               Value="Transparent"/>
      <Setter Property="Foreground"               Value="#CBD5E1"/>
      <Setter Property="BorderThickness"          Value="0"/>
      <Setter Property="RowBackground"            Value="Transparent"/>
      <Setter Property="AlternatingRowBackground" Value="#0F1923"/>
      <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
      <Setter Property="HorizontalGridLinesBrush" Value="#1E3A5F"/>
      <Setter Property="ColumnHeaderHeight"       Value="30"/>
      <Setter Property="RowHeight"                Value="28"/>
      <Setter Property="FontSize"                 Value="11"/>
      <Setter Property="SelectionMode"            Value="Single"/>
      <Setter Property="AutoGenerateColumns"      Value="False"/>
      <Setter Property="IsReadOnly"               Value="True"/>
      <Setter Property="CanUserResizeRows"        Value="False"/>
      <Setter Property="CanUserAddRows"           Value="False"/>
      <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
    </Style>

    <Style x:Key="DGH" TargetType="DataGridColumnHeader">
      <Setter Property="Background"      Value="#0F1923"/>
      <Setter Property="Foreground"      Value="#64748B"/>
      <Setter Property="FontSize"        Value="10"/>
      <Setter Property="FontWeight"      Value="SemiBold"/>
      <Setter Property="Padding"         Value="8,5"/>
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
      <Setter Property="BorderBrush"     Value="#1E3A5F"/>
    </Style>

    <Style x:Key="SmallBtn" TargetType="Button">
      <Setter Property="Background"      Value="#1E3A5F"/>
      <Setter Property="Foreground"      Value="#94A3B8"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="FontSize"        Value="10"/>
      <Setter Property="Padding"         Value="8,4"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="4"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

  </UserControl.Resources>

  <Grid Margin="4">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- 요약 카드 -->
    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Style="{StaticResource Card}">
        <StackPanel>
          <TextBlock Text="총 이벤트" Style="{StaticResource SecTitle}"/>
          <TextBlock Text="{Binding BlackboxEvents.Count}" Style="{StaticResource BigNum}" Foreground="#FB923C"/>
          <TextBlock Text="블랙박스 기록" Style="{StaticResource SubLabel}"/>
        </StackPanel>
      </Border>

      <Border Grid.Column="1" Style="{StaticResource Card}">
        <StackPanel>
          <TextBlock Text="오류 건수" Style="{StaticResource SecTitle}"/>
          <TextBlock Text="{Binding DeviceStatus.TodayErrorCount}" Style="{StaticResource BigNum}" Foreground="#F87171"/>
          <TextBlock Text="오늘 발생" Style="{StaticResource SubLabel}"/>
        </StackPanel>
      </Border>

      <Border Grid.Column="2" Style="{StaticResource Card}">
        <StackPanel>
          <TextBlock Text="로그인 기록" Style="{StaticResource SecTitle}"/>
          <TextBlock Text="{Binding LoginRecords.Count}" Style="{StaticResource BigNum}" Foreground="#A78BFA"/>
          <TextBlock Text="총 접속 이력" Style="{StaticResource SubLabel}"/>
        </StackPanel>
      </Border>

      <Border Grid.Column="3" Style="{StaticResource Card}">
        <StackPanel>
          <TextBlock Text="시스템 가동률" Style="{StaticResource SecTitle}"/>
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="{Binding DeviceStatus.SuccessRate}" Style="{StaticResource BigNum}" Foreground="#4ADE80"/>
            <TextBlock Text=" %" FontSize="16" Foreground="#4ADE80" VerticalAlignment="Bottom" Margin="1,0,0,4"/>
          </StackPanel>
          <TextBlock Text="금일 기준" Style="{StaticResource SubLabel}"/>
        </StackPanel>
      </Border>
    </Grid>

    <!-- 블랙박스 + 로그인 -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="1.2*"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- 블랙박스 -->
      <Border Grid.Column="0" Style="{StaticResource Card}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <Grid Grid.Row="0" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="▌ " Foreground="#FB923C" FontSize="14"/>
              <TextBlock Text="블랙박스 이벤트" FontSize="13" FontWeight="SemiBold" Foreground="#E2E8F0"/>
            </StackPanel>
            <Button Style="{StaticResource SmallBtn}" Content="초기화"
                    Command="{Binding ClearLogsCommand}" CommandParameter="blackbox"
                    HorizontalAlignment="Right"/>
          </Grid>

          <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="필터: " FontSize="10" Foreground="#64748B" VerticalAlignment="Center"/>
            <Border Background="#1E3A5F" CornerRadius="10" Padding="8,3" Margin="4,0">
              <TextBlock Text="전체" FontSize="10" Foreground="#94A3B8"/>
            </Border>
            <Border Background="#7C2D12" CornerRadius="10" Padding="8,3" Margin="4,0">
              <TextBlock Text="OCR실패" FontSize="10" Foreground="#FB923C"/>
            </Border>
            <Border Background="#7F1D1D" CornerRadius="10" Padding="8,3" Margin="4,0">
              <TextBlock Text="분류실패" FontSize="10" Foreground="#F87171"/>
            </Border>
            <Border Background="#1C3D5A" CornerRadius="10" Padding="8,3" Margin="4,0">
              <TextBlock Text="박스걸림" FontSize="10" Foreground="#38BDF8"/>
            </Border>
          </StackPanel>

          <DataGrid Grid.Row="2" ItemsSource="{Binding BlackboxEvents}" Style="{StaticResource DG}">
            <DataGrid.ColumnHeaderStyle>
              <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DGH}"/>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.RowStyle>
              <Style TargetType="DataGridRow">
                <Setter Property="Background" Value="Transparent"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Severity}" Value="오류">
                    <Setter Property="Background" Value="#1A0000"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
              <DataGridTextColumn Header="시각"     Binding="{Binding Timestamp, StringFormat=MM/dd HH:mm:ss}" Width="92"/>
              <DataGridTemplateColumn Header="유형" Width="68">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <Border CornerRadius="3" Padding="4,1" HorizontalAlignment="Center"
                            Background="{Binding EventType, Converter={StaticResource StatusToColor}}">
                      <TextBlock Text="{Binding EventType}" FontSize="10" Foreground="White"/>
                    </Border>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTemplateColumn Header="심각도" Width="48">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Severity}" FontSize="10" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{Binding Severity, Converter={StaticResource SeverityToColor}}"/>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="설명"     Binding="{Binding Description}" Width="*"/>
              <DataGridTemplateColumn Header="이미지" Width="68">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <Border Background="#0F2840" CornerRadius="3" Padding="4,2"
                            HorizontalAlignment="Center" Cursor="Hand">
                      <TextBlock Text="🖼 보기" FontSize="10" Foreground="#38BDF8"/>
                    </Border>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </Border>

      <!-- 로그인 기록 -->
      <Border Grid.Column="1" Style="{StaticResource Card}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <Grid Grid.Row="0" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="▌ " Foreground="#A78BFA" FontSize="14"/>
              <TextBlock Text="로그인 기록" FontSize="13" FontWeight="SemiBold" Foreground="#E2E8F0"/>
            </StackPanel>
            <Button Style="{StaticResource SmallBtn}" Content="초기화"
                    Command="{Binding ClearLogsCommand}" CommandParameter="login"
                    HorizontalAlignment="Right"/>
          </Grid>

          <DataGrid Grid.Row="1" ItemsSource="{Binding LoginRecords}" Style="{StaticResource DG}">
            <DataGrid.ColumnHeaderStyle>
              <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DGH}"/>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
              <DataGridTextColumn Header="시각"   Binding="{Binding Timestamp, StringFormat=MM/dd HH:mm}" Width="78"/>
              <DataGridTextColumn Header="사용자" Binding="{Binding UserName}"                            Width="52"/>
              <DataGridTextColumn Header="권한"   Binding="{Binding Role}"                                Width="68"/>
              <DataGridTemplateColumn Header="구분" Width="52">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <Border CornerRadius="3" Padding="4,1" HorizontalAlignment="Center"
                            Background="{Binding Action, Converter={StaticResource StatusToColor}}">
                      <TextBlock Text="{Binding Action}" FontSize="10" Foreground="White"/>
                    </Border>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="*"/>
              <DataGridTemplateColumn Header="결과" Width="38">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Text"       Value="✓"/>
                          <Setter Property="Foreground" Value="#4ADE80"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding Success}" Value="False">
                              <Setter Property="Text"       Value="✗"/>
                              <Setter Property="Foreground" Value="#F87171"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</UserControl>
