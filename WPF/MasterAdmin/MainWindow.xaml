<Window x:Class="MasterAdmin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MasterAdmin"
        mc:Ignorable="d"
        Title="MasterAdmin · 통합 관제 시스템"
        Height="900" Width="1440"
        MinHeight="720" MinWidth="1200"
        WindowState="Maximized"
        Background="{DynamicResource BgWindow}">

  <Window.Resources>

    <!-- 현장 탭 -->
    <Style x:Key="NavField" TargetType="Button">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="Foreground"      Value="{DynamicResource FgMuted}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"         Value="20,10"/>
      <Setter Property="FontSize"        Value="13"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="6" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgCard}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsFieldPage}" Value="True">
          <Setter Property="Background" Value="{DynamicResource AccentBg}"/>
          <Setter Property="Foreground" Value="{DynamicResource AccentFg}"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <!-- 총괄 탭 -->
    <Style x:Key="NavOverview" TargetType="Button">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="Foreground"      Value="{DynamicResource FgMuted}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"         Value="20,10"/>
      <Setter Property="FontSize"        Value="13"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="6" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgCard}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsOverviewPage}" Value="True">
          <Setter Property="Background" Value="{DynamicResource AccentBg}"/>
          <Setter Property="Foreground" Value="{DynamicResource AccentFg}"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <!-- 테마 토글 버튼 -->
    <Style x:Key="ThemeBtn" TargetType="Button">
      <Setter Property="Background"      Value="{DynamicResource SmBtnBg}"/>
      <Setter Property="Foreground"      Value="{DynamicResource FgSecondary}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"         Value="10,6"/>
      <Setter Property="FontSize"        Value="11"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="6" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="52"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- ══════════ 상단 바 ══════════ -->
    <Border Grid.Row="0"
            Background="{DynamicResource BgTopBar}"
            BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource BorderLine}">
      <Grid Margin="16,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>   <!-- 로고 -->
          <ColumnDefinition Width="Auto"/>   <!-- 탭 -->
          <ColumnDefinition Width="*"/>      <!-- 스페이서 -->
          <ColumnDefinition Width="Auto"/>   <!-- 상태 알약 -->
          <ColumnDefinition Width="Auto"/>   <!-- 디버그 버튼 -->
          <ColumnDefinition Width="Auto"/>   <!-- 테마 버튼 -->
          <ColumnDefinition Width="Auto"/>   <!-- 시계 -->
        </Grid.ColumnDefinitions>

        <!-- 로고 -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,24,0">
          <Border Background="{DynamicResource AccentBg}" CornerRadius="6"
                  Width="32" Height="32" Margin="0,0,10,0">
            <TextBlock Text="⬡" Foreground="{DynamicResource AccentFg}" FontSize="16"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="MASTER ADMIN" FontSize="13" FontWeight="Bold"
                       Foreground="{DynamicResource FgPrimary}"/>
            <TextBlock Text="통합 관제 시스템" FontSize="9"
                       Foreground="{DynamicResource FgMuted}"/>
          </StackPanel>
        </StackPanel>

        <!-- 탭 버튼 -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <Button Style="{StaticResource NavField}" Command="{Binding NavigateToFieldCommand}">
            <TextBlock Text="📡  현장 모니터링" FontSize="13"/>
          </Button>
          <Button Style="{StaticResource NavOverview}" Command="{Binding NavigateToOverviewCommand}">
            <TextBlock Text="📊  총괄 관제" FontSize="13"/>
          </Button>
        </StackPanel>

        <!-- 장비 상태 알약 -->
        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
          <Border Background="#1A2D1A" CornerRadius="12" Padding="10,4" Margin="3,0">
            <StackPanel Orientation="Horizontal">
              <Ellipse Width="6" Height="6" Fill="#4ADE80" VerticalAlignment="Center" Margin="0,0,5,0"/>
              <TextBlock Text="컨베이어" FontSize="10" Foreground="#4ADE80"/>
            </StackPanel>
          </Border>
          <Border Background="#1A1A2E" CornerRadius="12" Padding="10,4" Margin="3,0">
            <StackPanel Orientation="Horizontal">
              <Ellipse Width="6" Height="6" Fill="#60A5FA" VerticalAlignment="Center" Margin="0,0,5,0"/>
              <TextBlock Text="로봇팔" FontSize="10" Foreground="#60A5FA"/>
            </StackPanel>
          </Border>
          <Border Background="#1A2D1A" CornerRadius="12" Padding="10,4" Margin="3,0">
            <StackPanel Orientation="Horizontal">
              <Ellipse Width="6" Height="6" Fill="#4ADE80" VerticalAlignment="Center" Margin="0,0,5,0"/>
              <TextBlock Text="OCR / QR" FontSize="10" Foreground="#4ADE80"/>
            </StackPanel>
          </Border>
          <Border CornerRadius="12" Padding="10,4" Margin="3,0"
                  Background="{Binding IsEmergencyStop, Converter={StaticResource BoolToEmergencyColor}}">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="⚠  " FontSize="10" Foreground="White"/>
              <TextBlock FontSize="10" Foreground="White"
                         Text="{Binding IsEmergencyStop, Converter={StaticResource BoolToEmergencyText}}"/>
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- 디버그 창 버튼 -->
        <Button Grid.Column="4" Click="BtnDebug_Click"
                Background="#1E3A5F" BorderThickness="0"
                Padding="10,5" Cursor="Hand" Margin="0,0,6,0"
                VerticalAlignment="Center">
          <Button.Template>
            <ControlTemplate TargetType="Button">
              <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
            </ControlTemplate>
          </Button.Template>
          <TextBlock Text="🔍 디버그" FontSize="11" Foreground="#38BDF8"/>
        </Button>

        <!-- 🌙 / ☀ 테마 토글 버튼 -->
        <Button Grid.Column="5" Style="{StaticResource ThemeBtn}"
                Command="{Binding ToggleThemeCommand}"
                VerticalAlignment="Center" Margin="0,0,10,0">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="{Binding ThemeIcon}"  FontSize="14" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding ThemeLabel}" FontSize="11" VerticalAlignment="Center"
                       Margin="5,0,0,0" Foreground="{DynamicResource FgSecondary}"/>
          </StackPanel>
        </Button>

        <!-- 시계 -->
        <Border Grid.Column="6" Background="{DynamicResource BgInput}"
                CornerRadius="6" Padding="12,6" VerticalAlignment="Center">
          <TextBlock Text="{Binding CurrentTime}" FontSize="12"
                     Foreground="{DynamicResource FgSecondary}" FontFamily="Consolas"/>
        </Border>
      </Grid>
    </Border>

    <!-- ══════════ 콘텐츠 ══════════ -->
    <Grid Grid.Row="1">
      <local:FieldPage
          DataContext="{Binding}"
          Visibility="{Binding IsFieldPage, Converter={StaticResource BoolToVis}}"/>
      <local:OverviewPage
          DataContext="{Binding}"
          Visibility="{Binding IsOverviewPage, Converter={StaticResource BoolToVis}}"/>
    </Grid>
  </Grid>
</Window>
