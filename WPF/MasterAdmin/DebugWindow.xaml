<Window x:Class="MasterAdmin.DebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Flask 수신 이벤트 디버그" Height="500" Width="700"
        Background="#0D1B2A" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Flask WebSocket 수신 이벤트" FontSize="14" FontWeight="Bold"
                       Foreground="#38BDF8" VerticalAlignment="Center"/>
            <Border Background="#1E3A5F" CornerRadius="4" Padding="6,2" Margin="10,0,0,0">
                <TextBlock x:Name="TxtConnectionStatus" Text="연결 확인 중..." 
                           FontSize="11" Foreground="#94A3B8"/>
            </Border>
        </StackPanel>

        <Border Grid.Row="1" Background="#050E1A" CornerRadius="6" Padding="8">
            <ScrollViewer x:Name="Scroller" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="TxtLog" Foreground="#94A3B8" FontFamily="Consolas"
                           FontSize="11" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
            <Button x:Name="BtnClear" Content="로그 지우기" Click="BtnClear_Click"
                    Background="#1E3A5F" Foreground="#38BDF8" BorderThickness="0"
                    Padding="10,5" Cursor="Hand" Margin="0,0,8,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <TextBlock Text="* 영현이가 보내는 모든 이벤트가 여기 표시됩니다" 
                       Foreground="#475569" FontSize="10" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
