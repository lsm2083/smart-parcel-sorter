<Application x:Class="MasterAdmin.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MasterAdmin"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- ── 컨버터 ── -->
        <local:StatusToColorConverter        x:Key="StatusToColor"/>
        <local:SeverityToColorConverter      x:Key="SeverityToColor"/>
        <local:SuccessToColorConverter       x:Key="SuccessToColor"/>
        <local:BoolToVisibilityConverter     x:Key="BoolToVis"/>
        <local:BoolToEmergencyColorConverter x:Key="BoolToEmergencyColor"/>
        <local:BoolToEmergencyTextConverter  x:Key="BoolToEmergencyText"/>

        <!-- ══════════════════════════════════════════
             다크 테마 색상 (기본값)
             App.xaml.cs 에서 IsDark 에 따라 교체됨
        ══════════════════════════════════════════ -->

        <!-- 배경 계층 -->
        <SolidColorBrush x:Key="BgWindow"   Color="#0D1B2A"/>
        <SolidColorBrush x:Key="BgTopBar"   Color="#111D2B"/>
        <SolidColorBrush x:Key="BgCard"     Color="#1E2A3A"/>
        <SolidColorBrush x:Key="BgAltRow"   Color="#0F1923"/>
        <SolidColorBrush x:Key="BgInput"    Color="#0F1923"/>
        <SolidColorBrush x:Key="BgColHead"  Color="#0F1923"/>

        <!-- 텍스트 -->
        <SolidColorBrush x:Key="FgPrimary"  Color="#E2E8F0"/>
        <SolidColorBrush x:Key="FgSecondary" Color="#94A3B8"/>
        <SolidColorBrush x:Key="FgMuted"    Color="#64748B"/>
        <SolidColorBrush x:Key="FgData"     Color="#CBD5E1"/>

        <!-- 테두리 / 구분선 -->
        <SolidColorBrush x:Key="BorderLine" Color="#1E3A5F"/>

        <!-- 액센트 (탭 활성) -->
        <SolidColorBrush x:Key="AccentBg"   Color="#1E3A5F"/>
        <SolidColorBrush x:Key="AccentFg"   Color="#38BDF8"/>

        <!-- 버튼 소형 -->
        <SolidColorBrush x:Key="SmBtnBg"    Color="#1E3A5F"/>
        <SolidColorBrush x:Key="SmBtnFg"    Color="#94A3B8"/>

    </Application.Resources>
</Application>
