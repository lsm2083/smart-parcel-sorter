<UserControl x:Class="MasterAdmin.FieldPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:MasterAdmin"
             mc:Ignorable="d"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"   Value="{DynamicResource BgCard}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding"      Value="14"/>
            <Setter Property="Margin"       Value="4"/>
        </Style>
        <Style x:Key="SecTitle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource FgSecondary}"/>
            <Setter Property="Margin"     Value="0,0,0,8"/>
        </Style>
        <Style x:Key="BigNum" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="26"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource FgPrimary}"/>
        </Style>
        <Style x:Key="SubLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource FgMuted}"/>
            <Setter Property="Margin"     Value="0,2,0,0"/>
        </Style>
        <Style x:Key="DG" TargetType="DataGrid">
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="Foreground"               Value="{DynamicResource FgData}"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="RowBackground"            Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource BgAltRow}"/>
            <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderLine}"/>
            <Setter Property="ColumnHeaderHeight"       Value="30"/>
            <Setter Property="RowHeight"                Value="26"/>
            <Setter Property="FontSize"                 Value="11"/>
            <Setter Property="SelectionMode"            Value="Single"/>
            <Setter Property="AutoGenerateColumns"      Value="False"/>
            <Setter Property="IsReadOnly"               Value="True"/>
            <Setter Property="CanUserResizeRows"        Value="False"/>
            <Setter Property="CanUserAddRows"           Value="False"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        </Style>
        <Style x:Key="DGH" TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="{DynamicResource BgColHead}"/>
            <Setter Property="Foreground"      Value="{DynamicResource FgMuted}"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderLine}"/>
        </Style>
        <Style x:Key="SmallBtn" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource SmBtnBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource SmBtnFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DatePicker 내부 텍스트박스: 선택한 날짜가 흰 배경에 흰 글씨로 묻혀 안 보이는 문제 해결 -->
        <Style TargetType="DatePickerTextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePickerTextBox">
                        <Grid>
                            <Border Background="#0F172A" BorderBrush="#334155" BorderThickness="1" CornerRadius="3">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="4,0" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="PART_Watermark" Text="날짜 선택" Foreground="#64748B"
                                       Margin="6,0" VerticalAlignment="Center" IsHitTestVisible="False"
                                       Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="PART_Watermark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ 통계 바 ══ -->
        <Grid Grid.Row="0" Margin="4,4,4,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="170"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="오늘 처리 건수" Style="{StaticResource SecTitle}"/>
                    <TextBlock Text="{Binding DeviceStatus.TodaySortedCount}" Style="{StaticResource BigNum}" Foreground="#38BDF8"/>
                    <TextBlock Text="박스" Style="{StaticResource SubLabel}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="분류 성공률" Style="{StaticResource SecTitle}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding DeviceStatus.SuccessRate}" Style="{StaticResource BigNum}" Foreground="#4ADE80"/>
                        <TextBlock Text=" %" FontSize="16" Foreground="#4ADE80" VerticalAlignment="Bottom" Margin="1,0,0,3"/>
                    </StackPanel>
                    <TextBlock Text="인식 정확도" Style="{StaticResource SubLabel}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="오류 건수" Style="{StaticResource SecTitle}"/>
                    <TextBlock Text="{Binding DeviceStatus.TodayErrorCount}" Style="{StaticResource BigNum}" Foreground="#F87171"/>
                    <TextBlock Text="오늘 누적" Style="{StaticResource SubLabel}"/>
                </StackPanel>
            </Border>
            <!-- 컨베이어 제어 -->
            <Border Grid.Column="3" Style="{StaticResource Card}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="컨베이어 제어" Style="{StaticResource SecTitle}" HorizontalAlignment="Center"/>
                    <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Command="{Binding ConveyorStartCommand}"
                                Height="26" Cursor="Hand" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#166534" CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="▶ 시작" Foreground="#4ADE80" FontWeight="Bold" FontSize="10"/>
                        </Button>
                        <Button Grid.Column="2" Command="{Binding ConveyorStopCommand}"
                                Height="26" Cursor="Hand" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#7F1D1D" CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="■ 종료" Foreground="#F87171" FontWeight="Bold" FontSize="10"/>
                        </Button>
                    </Grid>
                    <Button Command="{Binding ConveyorResumeCommand}"
                            Height="26" Cursor="Hand" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#1E3A5F" CornerRadius="5">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="↺ 재개" Foreground="#38BDF8" FontWeight="Bold" FontSize="10"/>
                    </Button>
                    <TextBlock Text="{Binding DeviceStatus.ConveyorStatus}" FontSize="10"
                               HorizontalAlignment="Center" Margin="0,3,0,0"
                               Foreground="{Binding DeviceStatus.ConveyorStatus, Converter={StaticResource StatusToColor}}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource Card}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="비상정지" Style="{StaticResource SecTitle}" HorizontalAlignment="Center"/>
                    <Button Command="{Binding ToggleEmergencyCommand}"
                  Background="{Binding IsEmergencyStop, Converter={StaticResource BoolToEmergencyColor}}"
                  Height="52" Cursor="Hand" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel>
                            <TextBlock Text="⚠ 비상정지" Foreground="White" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding IsEmergencyStop, Converter={StaticResource BoolToEmergencyText}}"
                         Foreground="White" FontSize="10" Opacity="0.85" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══ 메인 콘텐츠 ══ -->
        <Grid Grid.Row="1" Margin="4,0,4,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="0.7*"/>
                </Grid.ColumnDefinitions>

                <!-- QR/OCR 카메라 (네트워크 스트림) -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                            <Ellipse Width="7" Height="7" Fill="#4ADE80" VerticalAlignment="Center" Margin="0,0,6,0">
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.2" Duration="0:0:1" AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <TextBlock Text="QR / OCR" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource FgPrimary}"/>
                            <TextBlock Text="  LIVE" FontSize="10" Foreground="#4ADE80" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border Grid.Row="1" Background="#050E1A" CornerRadius="6" ClipToBounds="True">
                            <Grid>
                                <Image x:Name="CamQrImg" Stretch="UniformToFill"/>
                                <StackPanel x:Name="CamQrPlaceholder" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📷" FontSize="26" HorizontalAlignment="Center"/>
                                    <TextBlock Text="QR / OCR CAM" FontSize="11" Foreground="#4ADE80"
                                               HorizontalAlignment="Center" Margin="0,5,0,0" FontFamily="Consolas"/>
                                    <TextBlock Text="연결 대기" FontSize="9" Foreground="#475569"
                                               HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Text="QR: " FontSize="10" Foreground="{DynamicResource FgMuted}"/>
                            <TextBlock Text="{Binding DeviceStatus.QrCamStatus}" FontSize="10" Margin="0,0,8,0"
                         Foreground="{Binding DeviceStatus.QrCamStatus, Converter={StaticResource StatusToColor}}"/>
                            <TextBlock Text="OCR: " FontSize="10" Foreground="{DynamicResource FgMuted}"/>
                            <TextBlock Text="{Binding DeviceStatus.OcrCamStatus}" FontSize="10"
                         Foreground="{Binding DeviceStatus.OcrCamStatus, Converter={StaticResource StatusToColor}}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 블랙박스 현장 CAM -->
                <Border Grid.Column="1" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                            <Ellipse Width="7" Height="7" Fill="#FB923C" VerticalAlignment="Center" Margin="0,0,6,0">
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.2" Duration="0:0:1.2" AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <TextBlock Text="블랙박스 · 현장" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource FgPrimary}"/>
                            <TextBlock Text="  LIVE" FontSize="10" Foreground="#FB923C" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Grid Grid.Row="1">
                            <Border Background="#050E1A" CornerRadius="6" ClipToBounds="True">
                                <Grid x:Name="FieldCamGrid"
                                      MouseDown="FieldCam_MouseDown"
                                      MouseMove="FieldCam_MouseMove"
                                      MouseUp="FieldCam_MouseUp"
                                      Cursor="Cross">
                                    <Image x:Name="CamFieldImg" Stretch="UniformToFill"/>
                                    <StackPanel x:Name="CamFieldPlaceholder" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="📷" FontSize="26" HorizontalAlignment="Center"/>
                                        <TextBlock Text="현장 CAM" FontSize="11" Foreground="#38BDF8"
                               HorizontalAlignment="Center" Margin="0,5,0,0" FontFamily="Consolas"/>
                                        <TextBlock Text="연결 대기" FontSize="9" Foreground="#475569"
                               HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <Canvas IsHitTestVisible="False">
                                        <Rectangle x:Name="FieldDrawingRect"
                                                   Stroke="#FF0000" StrokeThickness="2"
                                                   Fill="Transparent" Visibility="Collapsed"/>
                                    </Canvas>
                                    <Border Background="#CC000000" CornerRadius="4"
                                            Padding="6,4" Margin="4"
                                            VerticalAlignment="Bottom" HorizontalAlignment="Left">
                                        <TextBlock x:Name="FieldRoiGuideText"
                                                   Text="🖱 드래그: 현장 ROI 설정"
                                                   Foreground="White" FontSize="9" FontFamily="Consolas"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <Border CornerRadius="4" Padding="4,2" Margin="5,5,0,0"
                      Background="#0D1B2A" HorizontalAlignment="Left" VerticalAlignment="Top">
                                <TextBlock Text="현장 CAM" FontSize="9" Foreground="#38BDF8" FontFamily="Consolas"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 블랙박스 출고 CAM -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                            <Ellipse Width="7" Height="7" Fill="#C084FC" VerticalAlignment="Center" Margin="0,0,6,0">
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.2" Duration="0:0:1.4" AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <TextBlock Text="블랙박스 · 출고" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource FgPrimary}"/>
                            <TextBlock Text="  LIVE" FontSize="10" Foreground="#C084FC" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Grid Grid.Row="1">
                            <Border Background="#050E1A" CornerRadius="6" ClipToBounds="True">
                                <Grid x:Name="ShippingCamGrid"
                                      MouseDown="ShippingCam_MouseDown"
                                      MouseMove="ShippingCam_MouseMove"
                                      MouseUp="ShippingCam_MouseUp"
                                      Cursor="Cross">
                                    <Image x:Name="CamShippingImg" Stretch="UniformToFill"/>
                                    <StackPanel x:Name="CamShippingPlaceholder" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="📷" FontSize="26" HorizontalAlignment="Center"/>
                                        <TextBlock Text="출고 CAM" FontSize="11" Foreground="#C084FC"
                               HorizontalAlignment="Center" Margin="0,5,0,0" FontFamily="Consolas"/>
                                        <TextBlock Text="연결 대기" FontSize="9" Foreground="#475569"
                               HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <Canvas x:Name="RoiCanvas" IsHitTestVisible="False">
                                        <!-- ROI1: 감시 구역 고정 테두리 (빨간 점선) -->
                                        <Rectangle x:Name="Roi1Rect"
                                                   Stroke="#FF0000" StrokeThickness="2"
                                                   StrokeDashArray="4,2" Fill="#22FF0000"
                                                   Visibility="Collapsed"/>
                                        <TextBlock x:Name="Roi1Label" Text="ROI1 박스감지"
                                                   Foreground="#FF0000" FontSize="10" FontWeight="Bold"
                                                   Visibility="Collapsed"/>
                                        <!-- BoxDetect: 박스 진입 감지 (초록 실선) — OpenCV 컨투어 -->
                                        <Rectangle x:Name="BoxDetectRect"
                                                   Stroke="#00FF00" StrokeThickness="2"
                                                   Fill="#1100FF00"
                                                   Visibility="Collapsed"/>
                                        <TextBlock x:Name="BoxDetectLabel"
                                                   Foreground="#00FF00" FontSize="10" FontWeight="Bold"
                                                   Visibility="Collapsed"/>
                                        <!-- ROI2: 불량 검출 bbox (빨간 실선) — YOLO -->
                                        <Rectangle x:Name="Roi2Rect"
                                                   Stroke="#FF3232" StrokeThickness="2"
                                                   Fill="#44FF0000"
                                                   Visibility="Collapsed"/>
                                        <TextBlock x:Name="Roi2Label" Text="ROI2 불량검출"
                                                   Foreground="#FF3232" FontSize="10" FontWeight="Bold"
                                                   Visibility="Collapsed"/>
                                        <Rectangle x:Name="DrawingRect"
                                                   Stroke="#FFFF00" StrokeThickness="1"
                                                   Fill="Transparent" Visibility="Collapsed"/>
                                    </Canvas>
                                    <Border Background="#CC000000" CornerRadius="4"
                                            Padding="6,4" Margin="4"
                                            VerticalAlignment="Bottom" HorizontalAlignment="Left">
                                        <TextBlock x:Name="RoiGuideText"
                                                   Text="🖱 드래그: ROI1(박스) 설정"
                                                   Foreground="White" FontSize="9" FontFamily="Consolas"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <Border CornerRadius="4" Padding="4,2" Margin="5,5,0,0"
                      Background="#0D1B2A" HorizontalAlignment="Left" VerticalAlignment="Top">
                                <TextBlock Text="출고 CAM" FontSize="9" Foreground="#C084FC" FontFamily="Consolas"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 로봇팔 -->
                <Border Grid.Column="3" Style="{StaticResource Card}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="로봇팔 상태" Style="{StaticResource SecTitle}"/>

                            <Border Background="#0A1628" CornerRadius="6" Height="160" Margin="0,0,0,10">
                                <Canvas RenderTransformOrigin="0.5,0.5">
                                    <Canvas.RenderTransform>
                                        <RotateTransform Angle="0"/>
                                    </Canvas.RenderTransform>
                                    <Canvas.Style>
                                        <Style TargetType="Canvas">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRobotBusy}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard x:Name="RobotBusyStoryboard">
                                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                <DoubleAnimation
                                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                    From="-3"
                                                                    To="3"
                                                                    Duration="0:0:0.45"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <StopStoryboard BeginStoryboardName="RobotBusyStoryboard"/>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Canvas.Style>

                                    <Rectangle Canvas.Left="55" Canvas.Top="148" Width="40" Height="8" Fill="#334155" RadiusX="2" RadiusY="2"/>
                                    <Line X1="75" Y1="148" X2="50" Y2="105" Stroke="#38BDF8" StrokeThickness="6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Line X1="50" Y1="105" X2="95" Y2="68"  Stroke="#38BDF8" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Line X1="95" Y1="68"  X2="130" Y2="52" Stroke="#60A5FA" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Ellipse Canvas.Left="68"  Canvas.Top="141" Width="14" Height="14" Fill="#1E40AF" Stroke="#38BDF8" StrokeThickness="2"/>
                                    <Ellipse Canvas.Left="43"  Canvas.Top="98"  Width="14" Height="14" Fill="#1E40AF" Stroke="#38BDF8" StrokeThickness="2"/>
                                    <Ellipse Canvas.Left="88"  Canvas.Top="61"  Width="14" Height="14" Fill="#1E40AF" Stroke="#60A5FA" StrokeThickness="2"/>
                                    <Line X1="130" Y1="52" X2="145" Y2="44" Stroke="#94A3B8" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Line X1="130" Y1="52" X2="145" Y2="60" Stroke="#94A3B8" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Border>

                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="로봇팔" FontSize="11" Foreground="{DynamicResource FgMuted}"/>
                                <TextBlock Grid.Column="1" FontSize="11"
                                           Text="{Binding DeviceStatus.RobotArmStatus}"
                                           Foreground="{Binding DeviceStatus.RobotArmStatus, Converter={StaticResource StatusToColor}}"/>
                            </Grid>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="MQTT" FontSize="11" Foreground="{DynamicResource FgMuted}"/>
                                <TextBlock Grid.Column="1" FontSize="11"
                                           Text="{Binding IsRobotMqttConnected}"
                                           Foreground="{Binding DeviceStatus.RobotArmStatus, Converter={StaticResource StatusToColor}}"/>
                            </Grid>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="동작중" FontSize="11" Foreground="{DynamicResource FgMuted}"/>
                                <TextBlock Grid.Column="1" FontSize="11"
                                           Text="{Binding IsRobotBusy}"
                                           Foreground="#38BDF8"/>
                            </Grid>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="투입부" FontSize="11" Foreground="{DynamicResource FgMuted}"/>
                                <TextBlock Grid.Column="1" FontSize="11"
                                           Text="{Binding DeviceStatus.InputUnitStatus}"
                                           Foreground="{Binding DeviceStatus.InputUnitStatus, Converter={StaticResource StatusToColor}}"/>
                            </Grid>

                            <Separator Background="{DynamicResource BorderLine}" Margin="0,5"/>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="비상정지" FontSize="11" Foreground="{DynamicResource FgMuted}"/>
                                <TextBlock Grid.Column="1" FontSize="11"
                                           Text="{Binding IsEmergencyStop, Converter={StaticResource BoolToEmergencyText}}"
                                           Foreground="{Binding IsEmergencyStop, Converter={StaticResource BoolToEmergencyColor}}"/>
                            </Grid>

                            <TextBlock Text="{Binding RobotLastMessage}"
                                       TextWrapping="Wrap"
                                       FontSize="10"
                                       Foreground="{DynamicResource FgSecondary}"
                                       Margin="0,6,0,4"/>

                            <TextBlock Text="{Binding RobotCameraUrl}"
                                       TextWrapping="Wrap"
                                       FontSize="9"
                                       Foreground="#38BDF8"
                                       Margin="0,0,0,6"/>

                            <TextBlock Text="관절값" FontSize="10" Foreground="{DynamicResource FgMuted}" Margin="0,4,0,1"/>
                            <TextBlock Text="{Binding RobotAnglesText}" FontSize="9" Foreground="{DynamicResource FgSecondary}" TextWrapping="Wrap"/>

                            <TextBlock Text="좌표값" FontSize="10" Foreground="{DynamicResource FgMuted}" Margin="0,4,0,1"/>
                            <TextBlock Text="{Binding RobotCoordsText}" FontSize="9" Foreground="{DynamicResource FgSecondary}" TextWrapping="Wrap"/>

                            <Separator Background="{DynamicResource BorderLine}" Margin="0,8"/>

                            <TextBlock Text="로봇 제어" Style="{StaticResource SecTitle}" Margin="0,0,0,5"/>

                            <UniformGrid Columns="2" Margin="0,0,0,4">
                                <Button Style="{StaticResource SmallBtn}" Content="HOME" Command="{Binding RobotHomeCommand}" Margin="0,0,3,3"/>
                                <Button Style="{StaticResource SmallBtn}" Content="좌표" Command="{Binding RobotGetPoseCommand}" Margin="3,0,0,3"/>
                                <Button Style="{StaticResource SmallBtn}" Content="집게 열기" Command="{Binding RobotOpenGripperCommand}" Margin="0,3,3,3"/>
                                <Button Style="{StaticResource SmallBtn}" Content="집게 닫기" Command="{Binding RobotCloseGripperCommand}" Margin="3,3,0,3"/>
                                <Button Style="{StaticResource SmallBtn}" Content="집기준비" Command="{Binding RobotPickReadyCommand}" Margin="0,3,3,3"/>
                                <Button Style="{StaticResource SmallBtn}" Content="상태확인" Command="{Binding RobotStatusCommand}" Margin="3,3,0,3"/>
                            </UniformGrid>

                            <UniformGrid Columns="2" Margin="0,0,0,4">
                                <Button Content="STOP" Command="{Binding RobotStopCommand}"
                                        Background="#7F1D1D" Foreground="#FECACA" BorderThickness="0"
                                        FontSize="10" Padding="8,4" Cursor="Hand" Margin="0,0,3,3">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Content="비상해제" Command="{Binding RobotResetEmergencyCommand}"
                                        Background="#14532D" Foreground="#BBF7D0" BorderThickness="0"
                                        FontSize="10" Padding="8,4" Cursor="Hand" Margin="3,0,0,3">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </UniformGrid>

                            <TextBlock Text="슬롯 위치 테스트" Style="{StaticResource SecTitle}" Margin="0,4,0,5"/>

                            <UniformGrid Columns="3" Margin="0,0,0,4">
                                <Button Style="{StaticResource SmallBtn}" Content="1" Command="{Binding RobotPlaceTestCommand}" CommandParameter="1" Margin="0,0,3,3"/>
                                <Button Style="{StaticResource SmallBtn}" Content="2" Command="{Binding RobotPlaceTestCommand}" CommandParameter="2" Margin="3,0,3,3"/>
                                <Button Style="{StaticResource SmallBtn}" Content="3" Command="{Binding RobotPlaceTestCommand}" CommandParameter="3" Margin="3,0,0,3"/>
                                <Button Style="{StaticResource SmallBtn}" Content="4" Command="{Binding RobotPlaceTestCommand}" CommandParameter="4" Margin="0,3,3,3"/>
                                <Button Style="{StaticResource SmallBtn}" Content="5" Command="{Binding RobotPlaceTestCommand}" CommandParameter="5" Margin="3,3,3,3"/>
                                <Button Style="{StaticResource SmallBtn}" Content="6" Command="{Binding RobotPlaceTestCommand}" CommandParameter="6" Margin="3,3,0,3"/>
                                <Button Style="{StaticResource SmallBtn}" Content="7" Command="{Binding RobotPlaceTestCommand}" CommandParameter="7" Margin="0,3,3,0"/>
                                <Button Style="{StaticResource SmallBtn}" Content="8" Command="{Binding RobotPlaceTestCommand}" CommandParameter="8" Margin="3,3,3,0"/>
                                <Button Style="{StaticResource SmallBtn}" Content="9" Command="{Binding RobotPlaceTestCommand}" CommandParameter="9" Margin="3,3,0,0"/>
                            </UniformGrid>

                            <TextBlock Text="실제 SORT 테스트" Style="{StaticResource SecTitle}" Margin="0,8,0,5"/>

                            <UniformGrid Columns="3">
                                <Button Content="SORT 1" Command="{Binding RobotSortTestCommand}" CommandParameter="1"
                                        Background="#1E40AF" Foreground="#BFDBFE" BorderThickness="0" FontSize="10" Padding="8,4" Cursor="Hand" Margin="0,0,3,3">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Content="SORT 5" Command="{Binding RobotSortTestCommand}" CommandParameter="5"
                                        Background="#1E40AF" Foreground="#BFDBFE" BorderThickness="0" FontSize="10" Padding="8,4" Cursor="Hand" Margin="3,0,3,3">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Content="SORT 9" Command="{Binding RobotSortTestCommand}" CommandParameter="9"
                                        Background="#1E40AF" Foreground="#BFDBFE" BorderThickness="0" FontSize="10" Padding="8,4" Cursor="Hand" Margin="3,0,0,3">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </UniformGrid>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ═ 하단: 로그 ═ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="▌ " Foreground="#38BDF8" FontSize="14"/>
                                <TextBlock Text="분류 이력 로그" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource FgPrimary}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="BtnRefreshLogs" Style="{StaticResource SmallBtn}" Content="🔄 새로고침"
                                    Click="BtnRefreshLogs_Click" Margin="0,0,4,0"/>
                                <DatePicker x:Name="LogDatePicker" Width="120" FontSize="10"
                                    SelectedDateChanged="LogDatePicker_SelectedDateChanged"
                                    Background="#0F172A" Foreground="White" BorderBrush="#334155"/>
                                <Button Style="{StaticResource SmallBtn}" Content="전체날짜" Click="BtnShowAllDates_Click" Margin="4,0,4,0"/>
                                <Button Style="{StaticResource SmallBtn}" Content="초기화"
                          Command="{Binding ClearLogsCommand}" CommandParameter="sorting"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                            <Button x:Name="BtnSortAll" Content="전체" Click="BtnSortFilter_Click" Tag="전체"
                      Margin="0,0,4,0" Padding="8,3" FontSize="10" Cursor="Hand" BorderThickness="0"
                      Background="#1E40AF" Foreground="#BFDBFE">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button x:Name="BtnSortQR" Content="QR 인식 실패" Click="BtnSortFilter_Click" Tag="QR인식실패"
                      Margin="0,0,4,0" Padding="8,3" FontSize="10" Cursor="Hand" BorderThickness="0"
                      Background="#115E59" Foreground="#99F6E4">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button x:Name="BtnSortOCR" Content="OCR 인식 실패" Click="BtnSortFilter_Click" Tag="OCR인식실패"
                      Margin="0,0,4,0" Padding="8,3" FontSize="10" Cursor="Hand" BorderThickness="0"
                      Background="#9A3412" Foreground="#FDBA74">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button x:Name="BtnSortBox" Content="택배 상태" Click="BtnSortFilter_Click" Tag="택배상태"
                      Padding="8,3" FontSize="10" Cursor="Hand" BorderThickness="0"
                      Background="#5B21B6" Foreground="#DDD6FE">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                        <DataGrid x:Name="SortingGrid" Grid.Row="2" ItemsSource="{Binding SortingLogs}" Style="{StaticResource DG}">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DGH}"/>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="날짜/시각" Binding="{Binding Timestamp, StringFormat=MM/dd HH:mm:ss}" Width="85"/>
                                <DataGridTextColumn Header="운송장" Binding="{Binding TrackingNumber}" Width="82"/>
                                <DataGridTextColumn Header="인식" Binding="{Binding RecognitionType}" Width="36"/>
                                <DataGridTextColumn Header="권역" Binding="{Binding Region}" Width="40"/>
                                <DataGridTemplateColumn Header="상태" Width="48">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="3" Padding="4,1" HorizontalAlignment="Center" Background="{Binding Status, Converter={StaticResource StatusToColor}}">
                                                <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="택배상태" Width="55">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="3" Padding="4,1" HorizontalAlignment="Center" Background="{Binding BoxStatus, Converter={StaticResource StatusToColor}}">
                                                <TextBlock Text="{Binding BoxStatus}" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="최종판정" Width="55">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="3" Padding="4,1" HorizontalAlignment="Center" Background="{Binding FinalResult, Converter={StaticResource StatusToColor}}">
                                                <TextBlock Text="{Binding FinalResult}" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="오류유형" Binding="{Binding ErrorType}" Width="*"/>
                                <DataGridTemplateColumn Header="이미지" Width="55">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="🖼 보기" FontSize="10" Foreground="#38BDF8" Background="#0F2840" BorderThickness="0" Cursor="Hand" Padding="4,2"
                                                    Tag="{Binding ImagePath}"
                                                    Click="BtnViewImage_Click"
                                                    Visibility="{Binding ImagePath, Converter={StaticResource HasValueToVis}}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- ═ 이미지 미리보기 (분류이력 로그에서 이미지 클릭 시 표시) ═ -->
                <Border Grid.Column="1" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="▌ " Foreground="#C084FC" FontSize="14"/>
                                <TextBlock Text="이미지 미리보기" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource FgPrimary}"/>
                            </StackPanel>
                            <Button x:Name="BtnClearPreview" Style="{StaticResource SmallBtn}" Content="닫기" Click="BtnClearPreview_Click" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Grid.Row="1">
                            <!-- 이미지 미리보기 -->
                            <Image x:Name="PreviewImage" Stretch="Uniform" Visibility="Collapsed"/>
                            <!-- 플레이스홀더 -->
                            <StackPanel x:Name="PreviewPlaceholder" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="🖼" FontSize="40" HorizontalAlignment="Center" Opacity="0.3"/>
                                <TextBlock Text="분류이력 로그에서" FontSize="12" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                <TextBlock Text="이미지를 클릭하세요" FontSize="12" Foreground="#64748B" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>